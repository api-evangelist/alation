{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/alation/refs/heads/main/json-schema/alation-alation-governance-data-quality-rule-schema.json",
  "title": "DataQualityRule",
  "description": "A data quality rule for catalog objects",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "rule_type": {
      "type": "string"
    },
    "object_type": {
      "type": "string"
    },
    "object_id": {
      "type": "integer"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}